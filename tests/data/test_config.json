      "positions": ["early"],
      "samples_per_trajectory": 1
    },
    "judges": [
      {
        "name": "claude-3.5-sonnet",
        "model_id": "anthropic.claude-3-5-sonnet-20241022-v2:0",
        "provider": "aws_bedrock",
        "temperature": 0.7,
        "max_tokens": 2000
      }
    ],
    "annotation": {
      "method": "manual",
      "annotator": "test_researcher"
    },
    "random_seed": 42
  }
}
