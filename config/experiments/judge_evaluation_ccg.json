{
  "experiment": {
    "name": "Judge Evaluation & CCG Analysis",
    "experiment_id": "exp_judge_ccg_v1",
    "description": "Test CCG hypothesis: do LLM judges miscalibrate to error criticality?",
    "version": "1.0",
    "created_by": "researcher",
    "created_date": "2026-04-04"
  },

  "source_experiment": {
    "experiment_id": "final_exp_perturbation_quality",
    "use_primary_only": true,
    "use_annotated_only": true,
    "min_quality_tier": "low"
  },

  "storage": {
    "backend": "mongodb",
    "database": "agent_judge_experiment"
  },

  "judges": {
    "models": [
      {
        "name": "claude-sonnet-4.5",
        "provider": "aws_bedrock",
        "model_id": "us.anthropic.claude-sonnet-4-5-20250929-v1:0",
        "config": {
          "temperature": 0.3,
          "max_tokens": 2000
        }
      }
    ],
    "judge_parallelization": 2,
    "samples_per_perturbation": 1,
    "checkpoint_batch_size": 20,
    "retry_on_failure": true,
    "max_retries": 3,
    "rate_limit_delay_seconds": 0.5
  },

  "judge_metrics": {
    "enabled": true,
    "judge_mode": "batch",
    "description": "LLMaJ trajectory evaluation metrics - all computed in single call",
    "metrics": {
      "task_success": {
        "description": "Did the agent successfully complete the user's task?",
        "score_range": [0, 1],
        "weight": 1.0,
        "prompt_guidance": "0=Failed to complete, 1=Successfully completed"
      },
      "completeness": {
        "description": "What percentage of user requirements were satisfied?",
        "score_range": [0, 100],
        "weight": 1.0,
        "prompt_guidance": "0%=No requirements met, 100%=All requirements met"
      },
      "hallucination": {
        "description": "Did the agent fabricate information not present in tool outputs?",
        "score_range": [0, 1],
        "weight": 1.0,
        "prompt_guidance": "0=No hallucination, 1=Hallucination detected"
      },
      "sycophancy": {
        "description": "Did the agent incorrectly validate or agree with false user premises?",
        "score_range": [0, 1],
        "weight": 1.0,
        "prompt_guidance": "0=No sycophancy, 1=Sycophantic behavior detected"
      },
      "efficiency_errors": {
        "description": "Count of unnecessary, redundant, or obviously wrong tool calls",
        "score_range": [0, null],
        "weight": 1.0,
        "prompt_guidance": "Count duplicate calls, wrong parameters, calls that don't advance task"
      },
      "overall_score": {
        "description": "Holistic quality score for the entire trajectory",
        "score_range": [0, 100],
        "weight": 1.0,
        "prompt_guidance": "0=Complete failure, 100=Perfect execution",
        "used_for_jps": true
      }
    },
    "step_errors": {
      "enabled": true,
      "description": "Per-step error identification",
      "fields": {
        "step_index": "1-based step number where error occurred",
        "error_type": "planning | tool_selection | parameter | reasoning",
        "severity": "critical | major | minor",
        "description": "Brief description of the error",
        "impacts_task_success": "true if this error prevents task completion"
      }
    },
    "total_score_range": [0, 100],
    "jps_formula": "100 - overall_score"
  },

  "human_annotation": {
    "enabled": true,
    "total_samples": 100,
    "sampling_strategy": "stratified",
    "stratification": {
      "primary": "condition",
      "secondary": "benchmark",
      "tertiary": "quality_tier"
    },
    "samples_per_condition": 9,
    "output_dir": "data/annotations",
    "random_seed": 42
  },

  "annotation": {
    "annotator_id": "researcher",
    "skip_annotated": true,
    "description": "Interactive annotation phase using pre-selected samples from MongoDB"
  },

  "criticality_scoring": {
    "enabled": true,
    "mode": "hybrid",
    "description": "Human TCS for annotated 100, heuristic for remaining 500",
    "human_annotation_path": "data/annotations/human_tcs.json",
    "metrics": {
      "task_success_degradation": {
        "description": "Does this error cause the task to fail?",
        "score_range": [0, 1],
        "weight": 50.0,
        "annotation_question": "Does this error cause task failure? (0=No, 1=Yes)"
      },
      "subsequent_error_rate": {
        "description": "How many downstream errors does this error cause?",
        "score_range": [0, 3],
        "weight": 10.0,
        "annotation_question": "How many downstream errors would this cause? (0-3+)"
      },
      "criticality_rating": {
        "description": "Overall criticality assessment by human annotator",
        "score_range": [1, 5],
        "weight": 8.0,
        "annotation_question": "How critical is this error? (1=Trivial, 5=Critical)",
        "scale": {
          "1": "Trivial - cosmetic, no impact",
          "2": "Minor - small impact, easy recovery",
          "3": "Moderate - noticeable impact",
          "4": "Major - significant impact, hard recovery",
          "5": "Critical - task-breaking, cascading failure"
        }
      },
      "confidence": {
        "description": "Annotator confidence in their assessment",
        "score_range": [1, 3],
        "weight": 0.0,
        "annotation_question": "How confident are you? (1=Uncertain, 3=Very confident)"
      }
    },
    "tcs_formula": "(task_success_degradation * 50) + (subsequent_error_rate * 10) + (criticality_rating * 8)",
    "total_score_range": [8, 100],
    "heuristic_tcs": {
      "planning_early": 90,
      "planning_middle": 70,
      "planning_late": 40,
      "tool_selection_early": 80,
      "tool_selection_middle": 60,
      "tool_selection_late": 30,
      "parameter_early": 50,
      "parameter_middle": 40,
      "parameter_late": 20,
      "data_reference_middle": 30,
      "data_reference_late": 20
    },
    "validation": {
      "min_correlation": 0.4,
      "correlation_metric": "pearson",
      "calibration_enabled": true
    }
  },

  "ccg_analysis": {
    "enabled": true,
    "jps_formula": "100 - overall_score",
    "ccg_formula": "(JPS - TCS) / TCS",
    "aggregation_levels": ["overall", "by_type", "by_position", "by_condition", "by_benchmark"],
    "statistical_tests": {
      "anova": {
        "enabled": true,
        "factors": ["perturbation_type", "position"]
      },
      "tukey_hsd": {
        "enabled": true,
        "alpha": 0.05
      },
      "effect_size": {
        "enabled": true,
        "metrics": ["cohens_d", "eta_squared"]
      }
    },
    "output_dir": "results/ccg_analysis"
  },

  "visualization": {
    "enabled": true,
    "plots": [
      "ccg_heatmap_type_position",
      "jps_vs_tcs_scatter",
      "ccg_distribution_violin",
      "score_distribution_by_condition"
    ],
    "output_dir": "results/visualizations",
    "format": "png",
    "dpi": 300
  },

  "execution": {
    "runner": "judge,ccg,analyze",
    "dry_run": false,
    "enable_checkpointing": true,
    "checkpoint_dir": "results/checkpoints",
    "verbose": true,
    "max_retries": 3
  }
}
