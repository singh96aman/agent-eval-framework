# Environment variables for POC experiment
# IMPORTANT: Copy this to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)

# AWS Bedrock (for Claude-3.5-Sonnet)
AWS_REGION=us-east-1
# AWS credentials should be configured via AWS CLI or environment variables:
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# GPT-OSS 120B endpoint
GPT_OSS_ENDPOINT=http://your-gpt-oss-endpoint:port/v1
GPT_OSS_API_KEY=your_api_key_if_required

# Hugging Face (for dataset loading)
# Get token from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_huggingface_token_here

# MongoDB (for results storage)
# Format: mongodb://username:password@host:port/database
# Or for MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb://localhost:27017/agent_judge_experiment
MONGODB_DATABASE=agent_judge_experiment

# Experiment configuration
RANDOM_SEED=42
MAX_TRAJECTORIES_POC=50
