# Environment variables for POC experiment
# IMPORTANT: Copy this to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)

# ============================================================================
# AWS Bedrock Configuration (for LLM Judges)
# ============================================================================
# AWS credentials should be configured via AWS CLI or environment variables:
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# Judge 1: Claude 3.5 Sonnet via AWS Bedrock
AWS_BEDROCK_CLAUDE_3_5_SONNET=anthropic.claude-3-5-sonnet-20241022-v2:0

# Judge 2: GPT-OSS 120B via AWS Bedrock
# Note: Replace with actual Bedrock model ID for GPT-OSS
# Example format: meta.llama3-70b-instruct-v1:0 or similar
AWS_BEDROCK_GPT_OSS=your-gpt-oss-bedrock-model-id

# ============================================================================
# HuggingFace (for dataset loading)
# ============================================================================
# Get token from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ============================================================================
# MongoDB Atlas (for results storage)
# ============================================================================
# Install with: python -m pip install "pymongo[srv]"
# Get connection string from MongoDB Atlas → Connect → Drivers
MONGODB_URI=your_mongodb_atlas_connection_string_here
MONGODB_DATABASE=agent_judge_experiment

# Alternative - Local MongoDB (for development):
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DATABASE=agent_judge_experiment_local
